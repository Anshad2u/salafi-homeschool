generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  settings     String    @default("{}") // JSON string: { prayerSlots, rewards }
  createdAt    DateTime  @default(now())
  profiles     Profile[]
  tasks        Task[]
}

model Profile {
  id       String  @id @default(cuid())
  familyId String
  family   Family  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  role     String  @default("STUDENT") // ADMIN, TEACHER, STUDENT
  name     String
  avatar   String  @default("👤")
  pin      String  @default("0000")
  age      Int?
  grade    String?

  tasks  Task[]
  quran  QuranProgress[]
  skills SkillProgress[]
  books  Book[]
  studentPlans StudentPlan[]

  @@index([familyId])
}

model Task {
  id        String    @id @default(cuid())
  familyId  String
  family    Family    @relation(fields: [familyId], references: [id], onDelete: Cascade)
  profileId String
  profile   Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject   String
  title     String
  slot      String    @default("")
  date      String // YYYY-MM-DD
  status    String    @default("PLANNED") // PLANNED, TAUGHT, DONE
  score     Int?
  notes     String    @default("")
  doneAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([familyId, date])
  @@index([profileId, date])
}

model QuranProgress {
  id         String  @id @default(cuid())
  profileId  String
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  surahIndex Int // 0-113
  ayahs      Int     @default(0)

  @@unique([profileId, surahIndex])
}

model SkillProgress {
  id         String  @id @default(cuid())
  profileId  String
  profile    Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  subject    String
  skillIndex Int
  level      Int     @default(0) // 0 not started, 1 practicing, 2 proficient, 3 mastered

  @@unique([profileId, subject, skillIndex])
}

model Book {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  author    String   @default("")
  status    String   @default("READING") // READING, FINISHED, WISHLIST
  rating    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([profileId])
}

model CurriculumTopic {
  id                String @id
  subject           String
  strand            String
  level             Int    // 0-6 matching age groups
  ageGroup          String // "0-1", "1-2", etc
  title             String
  description       String
  category          String // introduction, practice, mastery
  estimatedSessions Int    @default(2)
  tags              String @default("[]") // JSON array
  prerequisites     String @default("[]") // JSON array of IDs
  materials         String @default("")

  dailyTasks DailyPlanTask[]
}

model StudentPlan {
  id            String   @id @default(cuid())
  profileId     String
  profile       Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  startDate     String   // YYYY-MM-DD
  totalDays     Int      @default(365)
  onboardingAge Int
  level         Int      // 0-6 derived from age
  knownTopics   String   @default("[]") // JSON array of topic IDs
  skippedTopics String   @default("[]") // JSON array of topic IDs
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  dailyPlans DailyPlan[]

  @@index([profileId])
}

model DailyPlan {
  id            String      @id @default(cuid())
  studentPlanId String
  studentPlan   StudentPlan @relation(fields: [studentPlanId], references: [id], onDelete: Cascade)
  date          String      // YYYY-MM-DD
  dayNumber     Int
  isCompleted   Boolean     @default(false)
  createdAt     DateTime    @default(now())

  tasks DailyPlanTask[]

  @@unique([studentPlanId, date])
  @@index([studentPlanId])
}

model DailyPlanTask {
  id              String        @id @default(cuid())
  dailyPlanId     String
  dailyPlan       DailyPlan     @relation(fields: [dailyPlanId], references: [id], onDelete: Cascade)
  topicId         String
  topic           CurriculumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  subject         String
  status          String        @default("pending") // pending, completed, skipped, not-needed, carried-over
  feedback        String        @default("") // teacher feedback note
  completedAt     DateTime?

  @@index([dailyPlanId])
  @@index([topicId])
}
